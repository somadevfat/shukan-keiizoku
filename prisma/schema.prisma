generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  image               String?
  timeZone            String               @default("Asia/Tokyo")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  emailVerified       DateTime?
  accounts            Account[]
  sessions            Session[]
  guestIdentity       GuestIdentity?
  habitTasks          HabitTask[]
  measurementSessions MeasurementSession[]
  dailyGoals          DailyGoal[]
  continuityReflections ContinuityReflection[]
}

model GuestIdentity {
  id        String   @id @default(cuid())
  userId    String   @unique
  tokenHash String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model HabitTask {
  id                  String               @id @default(cuid())
  userId              String
  name                String
  archivedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  measurementSessions MeasurementSession[]
  dailyGoals          DailyGoal[]

  @@index([userId, archivedAt])
}

model MeasurementSession {
  id        String    @id @default(cuid())
  userId    String
  taskId    String
  startedAt DateTime
  stoppedAt DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      HabitTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([taskId, startedAt])
}

model DailyGoal {
  id          String    @id @default(cuid())
  userId      String
  taskId      String
  localDate   DateTime  @db.Date
  goalSeconds Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        HabitTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, localDate])
  @@index([userId, localDate])
}

model ContinuityReflection {
  id         String   @id @default(cuid())
  userId     String
  obstacle   String   @default("")
  nextAction String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}
