generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  image               String?
  timeZone            String               @default("Asia/Tokyo")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  habitTasks          HabitTask[]
  measurementSessions MeasurementSession[]
  dailyGoals          DailyGoal[]
}

model HabitTask {
  id                  String               @id @default(cuid())
  userId              String
  name                String
  archivedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  measurementSessions MeasurementSession[]
  dailyGoals          DailyGoal[]

  @@index([userId, archivedAt])
}

model MeasurementSession {
  id        String    @id @default(cuid())
  userId    String
  taskId    String
  startedAt DateTime
  stoppedAt DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      HabitTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([taskId, startedAt])
}

model DailyGoal {
  id          String    @id @default(cuid())
  userId      String
  taskId      String
  localDate   DateTime  @db.Date
  goalSeconds Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        HabitTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, localDate])
  @@index([userId, localDate])
}
