APP_IMAGE="ghcr.io/owner/syukan-counter-todo:latest"
APP_DOMAIN="example.com"
POSTGRES_PASSWORD="replace-with-a-long-random-password"
DATABASE_URL="postgresql://app:replace-with-a-url-encoded-password@db:5432/syukan_counter?schema=public"
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
AUTH_GOOGLE_ID="replace-with-google-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-client-secret"
NEXTAUTH_URL="https://example.com"
