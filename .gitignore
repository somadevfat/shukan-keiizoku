# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results

# next.js
/.next/
/out/

# production
/build
/backups

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated
/src/generated

/src/generated/prisma

# セキュリティ関連（秘密鍵・暗号化証明書など）
*.key
*.pub
*.p12
*.pfx
*.der
*.crt
client_secret_*.json

# エディタ・IDE固有の設定（ローカル設定やシークレットの混入防止）
.idea/
.vscode/
*.sw?

# OS固有の一時ファイル
Thumbs.db
ehthumbs.db
Desktop.ini

# ローカルデータベース（認証情報やテストデータ等）
*.db
*.sqlite
*.sqlite-journal
